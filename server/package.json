{
  "name": "server",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "postinstall": "patch-package",
    "dev": "run-script-os",
    "server": "run-script-os",
    "dev:win32": "cross-env NODE_MODE=dev node-dev ./bin/www",
    "dev:linux": "cross-env NODE_MODE=dev sudo -E node ./node_modules/.bin/node-dev ./bin/www",
    "server:win32": "cross-env NODE_MODE=deploy node ./bin/www",
    "server:linux": "cross-env NODE_MODE=deploy sudo -E node ./bin/www"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "check-disk-space": "^3.4.0",
    "compression": "^1.8.1",
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "debug": "~2.6.9",
    "diff": "^9.0.0",
    "dotenv": "^16.3.1",
    "express": "~4.16.1",
    "fs-extra": "^11.1.1",
    "http-errors": "~1.6.3",
    "jschardet": "^3.1.4",
    "mime": "^3.0.0",
    "morgan": "~1.9.1",
    "node-pty": "^1.1.0",
    "patch-package": "^8.0.1",
    "run-script-os": "^1.1.6",
    "serve-handler": "^6.1.5",
    "systeminformation": "^5.31.7",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "node-dev": "^8.0.0"
  }
}
